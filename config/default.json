{
    "reporterEnabled": "mocha-summary-report,mochawesome",
    "mochawesomeReporterOptions": {
        "inline": true,
        "code": false,
        "charts": true,
        "json": false,
        "html": true,
        "quiet": false,
        "reportDir": "test_report",
        "reportFilename": "test-report.html",
        "reportPageTitle": "Test Report"
    },
    "mochaSummaryReportReporterOptions": {
        "consoleSummary": "false",
        "textFileSummary": "false",
        "htmlSummary": "true",
        "testsFolder": "./test",
        "output": "test_report",
        "tagPrefix": "@",
        "testIDPrefix": "$",
        "testPhases": ["smoke", "regression", "e2e"],
        "passRateGreen": 80,
        "passRateAmber": 65,
        "otherReportLink": "test-report.html",
        "includeMochaBase": false,
        "environmentVar": "TESTENV",
        "projectName": "ZEPHYR_PROJECT_NAME",
        "projectVersion": "ZEPHYR_VERSION",
        "projectCycle": "ZEPHYR_CYCLE_NAME",
        "manualTestLink": "ZEPHYR_URL"
    },
    "envData": {
        "TESTENV": "dev",
        "ZEPHYR_UPDATE": "no",
        "ZEPHYR_USER": "CDTester",
        "ZEPHYR_PROJECT_NAME": "proj1",
        "ZEPHYR_VERSION": "1",
        "ZEPHYR_CYCLE_NAME": "Cycle 123",
        "ZEPHYR_CLONE_CYCLE": "no",
        "ZEPHYR_CLONE_VERSION": "Master_Test_Suite",
        "ZEPHYR_CLONE_CYCLE_NAME": "Smoke_Tests",
        "ZEPHYR_CYCLE": "smoke_test",
        "ZEPHYR_URL": "https://company.domain/jira/browse/"
    }
}